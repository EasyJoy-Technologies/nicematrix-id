# ===== NiceMatrix ID (.env.example) =====

# Public domain
LOGTO_ENDPOINT=https://id.nicematrix.com

# Logto core secrets (replace in production)
LOGTO_COOKIE_SECRET=replace-with-strong-random
LOGTO_ADMIN_DISABLE_LOCALHOST=false

# Postgres for Logto
POSTGRES_DB=logto
POSTGRES_USER=logto
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Logto service ports (internal)
LOGTO_PORT=3001

# Optional SMTP for verification/reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nicematrix.com
